# Archivo de variables de entorno (EJEMPLO)
#
# Instrucciones:
# 1. Copiar este archivo como .env (sin el .example)
# 2. Llenar con tus valores locales
# 3. El archivo .env está en .gitignore (no se versionará)

# ==================== CONFIGURACIÓN DE DATOS ====================
DATA_RAW_PATH=data/raw/BasePI.xlsx
DATA_PROCESSED_PATH=data/processed/
RANDOM_STATE=42
TARGET_COLUMN=target

# ==================== CONFIGURACIÓN DE MODELOS ====================
MODELS_PATH=models/
RESULTS_PATH=results/

# ==================== CONFIGURACIÓN DE LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/training.log

# ==================== CONFIGURACIÓN DE TUNING ====================
OPTUNA_N_TRIALS=50
OPTUNA_TIMEOUT=600

# ==================== CONFIGURACIÓN DE ENTRENAMIENTO ====================
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.001
VALIDATION_SPLIT=0.2

# ==================== CONFIGURACIÓN DE REPRODUCIBILIDAD ====================
USE_GPU=False
NUM_WORKERS=4
